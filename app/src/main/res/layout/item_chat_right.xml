<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp">

    <TextView
        android:id="@+id/tvTimestampRight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textAlignment="center"
        android:textColor="@android:color/darker_gray"
        android:textSize="12sp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvRevokeRight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@android:color/darker_gray"
        android:textSize="12sp"
        android:padding="8dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvSystemMessageRight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textAlignment="center"
        android:textColor="@android:color/darker_gray"
        android:textSize="12sp"
        android:padding="8dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/llNormalContentRight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="64dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvContentRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="240dp"
                android:minHeight="46dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_chat_bubble_right"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="16sp"
                android:padding="12dp"
                android:autoLink="web" />

            <!-- Voice to text container for right side -->
            <LinearLayout
                android:id="@+id/llVoiceContainerRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginTop="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvVoiceToTextBtnRight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="转文字"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="12sp"
                        android:padding="4dp" />

                    <TextView
                        android:id="@+id/tvVoiceRight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/bg_chat_bubble_right"
                        android:gravity="center_vertical"
                        android:drawableEnd="@android:drawable/ic_btn_speak_now"
                        android:drawablePadding="8dp"
                        android:text="3&quot;"
                        android:textColor="?attr/colorOnPrimary"
                        android:textSize="16sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvVoiceTextRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxWidth="240dp"
                    android:background="@drawable/bg_chat_bubble_right"
                    android:textColor="?attr/colorOnPrimary"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:visibility="gone" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivImageRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="120dp"
                android:minHeight="120dp"
                android:maxWidth="300dp"
                android:maxHeight="300dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/flVirtualImageRight"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_virtual_image"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="?attr/colorTextSecondary" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/llQuoteRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_quote_bubble"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:maxWidth="240dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvQuoteContentRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp"
                    android:maxLines="3"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivAvatarRight"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_launcher_round" />
    </LinearLayout>

</LinearLayout>
