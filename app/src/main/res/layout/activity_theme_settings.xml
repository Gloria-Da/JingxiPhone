<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorPrimary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="返回"
            app:tint="?attr/colorOnPrimary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="外观主题"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimary"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择主题颜色"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginBottom="16dp"/>

            <RadioGroup
                android:id="@+id/rgThemes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_round"
                android:padding="16dp">

                <RadioButton
                    android:id="@+id/rbThemeYellow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="奶黄 (默认)"
                    android:textSize="16sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:padding="8dp" />

                <RadioButton
                    android:id="@+id/rbThemePink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="粉色"
                    android:textSize="16sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:padding="8dp" />

                <RadioButton
                    android:id="@+id/rbThemeBlue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="浅蓝"
                    android:textSize="16sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:padding="8dp" />

                <RadioButton
                    android:id="@+id/rbThemeWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="纯白"
                    android:textSize="16sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:padding="8dp" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="深色模式设置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"/>

            <RadioGroup
                android:id="@+id/rgNightMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_round"
                android:padding="16dp">

                <RadioButton
                    android:id="@+id/rbNightFollowSystem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="跟随系统"
                    android:textSize="16sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:padding="8dp" />

                <RadioButton
                    android:id="@+id/rbNightYes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="始终开启"
                    android:textSize="16sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:padding="8dp" />

                <RadioButton
                    android:id="@+id/rbNightNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="始终关闭"
                    android:textSize="16sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:padding="8dp" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="桌面背景图片"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_round"
                android:padding="16dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ivBgPreview"
                    android:layout_width="200dp"
                    android:layout_height="300dp"
                    android:scaleType="centerCrop"
                    android:background="?attr/colorDivider"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal">

                    <Button
                        android:id="@+id/btnSelectBg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选择图片"
                        android:layout_marginEnd="16dp"
                        android:backgroundTint="?attr/colorSecondary"/>

                    <Button
                        android:id="@+id/btnClearBg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="恢复默认背景色"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="功能背景图片"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_round"
                android:padding="16dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ivGlobalBgPreview"
                    android:layout_width="200dp"
                    android:layout_height="300dp"
                    android:scaleType="centerCrop"
                    android:background="?attr/colorDivider"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal">

                    <Button
                        android:id="@+id/btnSelectGlobalBg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选择图片"
                        android:layout_marginEnd="16dp"
                        android:backgroundTint="?attr/colorSecondary"/>

                    <Button
                        android:id="@+id/btnClearGlobalBg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="跟随桌面背景"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>