<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.yoyo.jingxi.ui.widget.SwipeMenuLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clMainContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/colorCardBackground">

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_launcher_round"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvPersonaName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="人设名称"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorTextPrimary"
                        app:layout_constraintTop_toTopOf="@+id/ivAvatar"
                        app:layout_constraintStart_toEndOf="@+id/ivAvatar"
                        app:layout_constraintEnd_toStartOf="@id/tvMainBadge"/>

                    <TextView
                        android:id="@+id/tvMainBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="主人设"
                        android:textSize="12sp"
                        android:textColor="@color/colorAccent"
                        android:background="@drawable/bg_main_badge"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:visibility="gone"
                        app:layout_constraintTop_toTopOf="@id/tvPersonaName"
                        app:layout_constraintBottom_toBottomOf="@id/tvPersonaName"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvPersonaDesc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="人设描述..."
                        android:textSize="14sp"
                        android:textColor="?attr/colorTextSecondary"
                        android:layout_marginTop="4dp"
                        android:maxLines="2"
                        android:ellipsize="end"
                        app:layout_constraintTop_toBottomOf="@id/tvPersonaName"
                        app:layout_constraintStart_toStartOf="@+id/tvPersonaName"
                        app:layout_constraintEnd_toStartOf="@id/btnSetMain" />

                    <Button
                        android:id="@+id/btnSetMain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="设为主人设"
                        android:textSize="12sp"
                        style="@style/Widget.AppCompat.Button.Borderless.Colored"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvDelete"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="8dp"
                android:layout_marginEnd="16dp"
                android:background="#FF3B30"
                android:gravity="center"
                android:text="删除"
                android:textColor="@color/white"
                android:textSize="16sp" />

        </LinearLayout>
    </com.yoyo.jingxi.ui.widget.SwipeMenuLayout>
</FrameLayout>
