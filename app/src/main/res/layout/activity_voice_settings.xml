<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Light"
        app:titleTextColor="?attr/colorTextPrimary"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="注：语速等个性化设置已迁移至好友/角色编辑界面单独设置。"
                android:textSize="14sp"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="24dp" />

            <!-- MiniMax TTS Config -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MiniMax 语音配置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorTextPrimary"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMinimaxGroupId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="MiniMax Group ID" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMinimaxApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="MiniMax API Key"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MiniMax 语音合成功能需要配置 Group ID。"
                android:textSize="12sp"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="16dp" />

            <!-- MiniMax Model Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="语音模型"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="16sp"
                    android:layout_gravity="center_vertical"/>

                <Spinner
                    android:id="@+id/spinnerMinimaxModel"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_edit_text_rounded" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="启用语气词与停顿标签"
                    android:textSize="16sp"
                    android:textColor="?attr/colorTextPrimary" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchMinimaxToneTags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="提示：仅当模型为 speech-2.8-hd 或 speech-2.8-turbo 时支持。\n开启后，AI在生成语音时会加入 (laughs) 等语气词和 &lt;#x#&gt; 停顿控制。"
                android:textSize="12sp"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="由主API控制语音情绪"
                    android:textSize="16sp"
                    android:textColor="?attr/colorTextPrimary" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchMinimaxEmotion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开启后，在生成语音时会由AI分析对话情绪并应用到语音中。\n(不同模型支持的情绪参数不同，模型会自动匹配)"
                android:textSize="12sp"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="16dp" />

            <!-- MiniMax Volume -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="音量 (Volume): "
                    android:textColor="?attr/colorTextPrimary" />

                <SeekBar
                    android:id="@+id/seekBarVolume"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="10" />

                <EditText
                    android:id="@+id/etVolumeValue"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:text="1.0"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:padding="4dp" />
            </LinearLayout>

>>>>>>>>>

            <!-- MiniMax Pitch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="基频/变声 (Pitch): "
                    android:textColor="?attr/colorTextPrimary" />

                <SeekBar
                    android:id="@+id/seekBarPitch"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:max="24"
                    android:progress="12" />

                <EditText
                    android:id="@+id/etPitchValue"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:inputType="numberSigned"
                    android:text="0"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:padding="4dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <!-- STT Config -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STT (语音转文字) 配置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorTextPrimary"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSttBaseUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="STT Base URL"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSttApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="STT API Key"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSttModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="STT 模型 (如 FunAudioLLM/SenseVoiceSmall)" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Global Save Button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:backgroundTint="@color/colorPrimaryDark"
                android:textColor="?attr/colorTextPrimary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:text="保存配置" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
