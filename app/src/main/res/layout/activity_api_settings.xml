<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Light"
        app:titleTextColor="?attr/colorTextPrimary"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API 配置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorTextPrimary"
                android:layout_marginBottom="16dp" />

            <!-- API Address -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiEndpoint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="API 地址 (Endpoint)"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- API Key -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="API 秘钥 (Key)" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="聊天配置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorTextPrimary"
                android:layout_marginBottom="16dp" />

            <!-- Model Selection & Fetch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Spinner
                    android:id="@+id/spinnerModel"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_edit_text_rounded" />

                <Button
                    android:id="@+id/btnFetchModels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/colorPrimaryDark"
                    android:textColor="?attr/colorTextPrimary"
                    android:text="拉取模型" />
            </LinearLayout>

            <!-- Temperature Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="温度 (Temperature): "
                    android:textColor="?attr/colorTextPrimary" />

                <SeekBar
                    android:id="@+id/seekBarTemperature"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:max="20"
                    android:progress="8" />

                <EditText
                    android:id="@+id/etTemperatureValue"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:text="0.8"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:padding="4dp" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="提示：较高的值(如1.2以上)会使输出更加随机，而较低的值(如0.2)会使其更加集中和确定。0.8是一个推荐的平衡值。"
                android:textSize="12sp"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Image Generation Settings Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="生图配置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorTextPrimary"
                android:layout_marginBottom="16dp" />

            <!-- Enable Image Generation Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="启用AI生图"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="16sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchEnableImageGen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开启后，将调用配置的生图接口生成真实图片。"
                android:textSize="12sp"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etImageApiEndpoint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="生图 API 地址 (Endpoint)"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etImageApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="生图 API 秘钥 (Key)" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Image Model Selection & Fetch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Spinner
                    android:id="@+id/spinnerImageModel"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_edit_text_rounded" />

                <Button
                    android:id="@+id/btnFetchImageModels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/colorPrimaryDark"
                    android:textColor="?attr/colorTextPrimary"
                    android:text="拉取生图模型" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="和风天气配置 (QWeather)"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorTextPrimary"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etQWeatherHost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="API Host (如 abc123.def.qweatherapi.com)"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="在控制台→设置中查看你的专属 API Host，每个账号唯一。"
                android:textSize="12sp"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etQWeatherKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="和风天气 API Key (可选)" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="如果不填，将默认使用 OpenMeteo 免费服务获取天气。填写和风天气 Key (可去 qweather.com 免费申请) 可获得更精准的国内天气及逐小时预报。"
                android:textSize="12sp"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <!-- Preset Saving Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API配置预设管理"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorTextPrimary"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etPresetName"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:paddingHorizontal="12dp"
                    android:background="@drawable/bg_edit_text_rounded"
                    android:hint="输入预设名称" />

                <Button
                    android:id="@+id/btnSavePreset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/colorPrimaryDark"
                    android:textColor="?attr/colorTextPrimary"
                    android:text="保存为预设" />
            </LinearLayout>

            <Spinner
                android:id="@+id/spinnerPreset"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_edit_text_rounded" />

            <!-- Global Save Button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:backgroundTint="@color/colorPrimaryDark"
                android:textColor="?attr/colorTextPrimary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:text="保存所有配置" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
