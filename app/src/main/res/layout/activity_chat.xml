<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Light"
        app:titleTextColor="?attr/colorTextPrimary"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:orientation="horizontal">
            
            <ImageView
                android:id="@+id/ivChatBgSettings"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="?attr/colorTextPrimary"
                android:contentDescription="更改背景" />

            <ImageView
                android:id="@+id/ivChatSettings"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="?attr/colorTextPrimary"
                android:contentDescription="设置" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        
        <ImageView
            android:id="@+id/ivChatBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:clipToPadding="false" />
    </RelativeLayout>

    <!-- 引用预览区域 -->
    <LinearLayout
        android:id="@+id/layoutQuotePreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorCardBackground"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="?attr/colorDivider"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvQuotePreview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/ivCloseQuote"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="?attr/colorTextSecondary"
            android:contentDescription="取消引用" />
    </LinearLayout>

    <!-- 输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorCardBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <ImageView
            android:id="@+id/ivVoiceToggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:padding="2dp"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="?attr/colorTextPrimary"
            android:contentDescription="切换输入" />

        <ImageView
            android:id="@+id/ivEmoji"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:contentDescription="表情" />

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="输入消息..."
            android:maxLines="4"
            android:minHeight="40dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btnVoiceRecord"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_white_round"
            android:text="按住 说话"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="16sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="发送" />

        <ImageView
            android:id="@+id/ivAdd"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="?attr/colorTextPrimary"
            android:contentDescription="更多" />
    </LinearLayout>

    <!-- Recording Overlay -->
    <FrameLayout
        android:id="@+id/flRecordingOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="-200dp"
        android:background="#80000000"
        android:padding="24dp"
        android:visibility="gone"
        android:elevation="10dp">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            
            <ImageView
                android:id="@+id/ivRecordingIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_btn_speak_now" />
                
            <TextView
                android:id="@+id/tvRecordingHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="手指上滑，取消发送"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Voice Confirmation Dialog -->
    <FrameLayout
        android:id="@+id/flVoiceConfirmOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:elevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_white_round"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_margin="8dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="确认发送的语音文本"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etVoiceConfirmText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorDivider"
                android:minHeight="80dp"
                android:padding="12dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnVoiceCancel"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="取消" />

                <Button
                    android:id="@+id/btnVoiceSend"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="发送" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- 表情面板 -->
    <LinearLayout
        android:id="@+id/layoutEmojiPanel"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:background="?android:attr/windowBackground"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutEmojiGroups"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabMode="scrollable" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEmojiPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- 底部功能面板 -->
    <LinearLayout
        android:id="@+id/layoutFunctionPanel"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:background="?android:attr/windowBackground"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="16dp">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:rowCount="2">

            <LinearLayout
                android:id="@+id/btnFuncImage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_main_badge"
                    android:padding="12dp"
                    app:tint="?attr/colorTextPrimary"
                    android:src="@android:drawable/ic_menu_gallery"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="图片"
                    android:textSize="12sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFuncVoice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_main_badge"
                    android:padding="12dp"
                    app:tint="?attr/colorTextPrimary"
                    android:src="@android:drawable/ic_btn_speak_now"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="语音"
                    android:textSize="12sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFuncCall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_main_badge"
                    android:padding="12dp"
                    app:tint="?attr/colorTextPrimary"
                    android:src="@android:drawable/ic_menu_call"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="电话"
                    android:textSize="12sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFuncRegenerate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_main_badge"
                    android:padding="12dp"
                    app:tint="?attr/colorTextPrimary"
                    android:src="@android:drawable/ic_popup_sync"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重回"
                    android:textSize="12sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFuncSchedule"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_main_badge"
                    android:padding="12dp"
                    app:tint="?attr/colorTextPrimary"
                    android:src="@android:drawable/ic_menu_today"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="日程表"
                    android:textSize="12sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFuncMemo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_main_badge"
                    android:padding="12dp"
                    app:tint="?attr/colorTextPrimary"
                    android:src="@android:drawable/ic_menu_agenda"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="备忘录"
                    android:textSize="12sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </GridLayout>
    </LinearLayout>

</LinearLayout>
